# ============================================
# 火山引擎视觉智能 API 配置
# ============================================

# 火山引擎访问密钥（必填）
# 获取地址：https://console.volcengine.com/iam/keymanage/
VITE_VOLC_ACCESS_KEY_ID=你的AccessKeyId
VITE_VOLC_SECRET_ACCESS_KEY=你的SecretAccessKey（Base64编码）

# 火山引擎 API 区域配置（可选）
VITE_VOLC_API_REGION=cn-beijing
VITE_VOLC_API_SERVICE=cv

# ============================================
# 视频生成配置
# ============================================
# 视频生成使用火山引擎（即梦AI）API
# 配置在 VITE_VOLC_ACCESS_KEY_ID 和 VITE_VOLC_SECRET_ACCESS_KEY 中
# 后端端点：/api/volcengine/text-to-video

# ============================================
# 百度智能云数字人 API配置（可选）
# ============================================
VITE_BAIDU_DH_APP_ID=你的App_ID
VITE_BAIDU_DH_APP_KEY=你的App_Key

# ============================================
# 后端服务配置
# ============================================
VITE_BACKEND_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:8080/api

# ============================================
# 使用说明
# ============================================
# 1. 复制此文件为 .env.local
# 2. 将上面的占位符替换为实际密钥
# 3. 保存文件
# 4. 重启开发服务器：npm run dev
# 5. 确认控制台显示"✅ 火山引擎 API 已配置"
#
# 注意：
# - .env.local 已在 .gitignore 中，不会被提交到Git
# - 密钥请妥善保管，切勿公开
# - 部署时在平台环境变量中配置这些值
# ============================================
